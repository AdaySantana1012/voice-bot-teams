{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "com.voicebot.teams.tab",
  "developer": {
    "name": "Tu Empresa",
    "websiteUrl": "https://TU-URL-AQUI.com",
    "privacyUrl": "https://TU-URL-AQUI.com/privacy",
    "termsOfUseUrl": "https://TU-URL-AQUI.com/terms"
  },
  "name": {
    "short": "Voice Bot",
    "full": "Voice Bot - Asistente por Voz"
  },
  "description": {
    "short": "Habla con tu bot de Copilot Studio",
    "full": "Tab de Teams para enviar mensajes de voz a tu bot de Copilot Studio mediante Direct Line."
  },
  "icons": {
    "color": "icon-color.png",
    "outline": "icon-outline.png"
  },
  "accentColor": "#7c6af7",
  "staticTabs": [
    {
      "entityId": "voicebot",
      "name": "Voice Bot",
      "contentUrl": "https://TU-URL-AQUI.com/index.html",
      "scopes": ["personal"]
    }
  ],
  "configurableTabs": [
    {
      "configurationUrl": "https://TU-URL-AQUI.com/config.html",
      "canUpdateConfiguration": true,
      "scopes": ["team", "groupchat"]
    }
  ],
  "permissions": ["identity", "messageTeamMembers"],
  "devicePermissions": ["microphone"],
  "validDomains": ["TU-URL-AQUI.com"]
}
